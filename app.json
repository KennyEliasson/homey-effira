{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.kennyeliasson.effira",
  "version": "0.0.2",
  "compatibility": ">=12.4.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Effira Community",
    "sv": "Effira Community"
  },
  "description": {
    "en": "Monitor and automate your heat pump control with Effira Energy OPTi.",
    "sv": "Övervaka och automatisera din värmepumsstyrning med Effira Energy OPTi."
  },
  "brandColor": "#062121",
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Kenny Eliasson",
    "email": "kennyeliasson@gmail.com"
  },
  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Daily heatpump consumption changed"
        },
        "tokens": [
          {
            "name": "consumption_kwh",
            "type": "number",
            "title": {
              "en": "Consumption kWh"
            }
          },
          {
            "name": "previous_consumption_kwh",
            "type": "number",
            "title": {
              "en": "Previous consumption kWh"
            }
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "heatpump_consumption_changed"
      },
      {
        "title": {
          "en": "Planned control changed"
        },
        "titleFormatted": {
          "en": "Planned control changed to [[state]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "state",
            "type": "dropdown",
            "title": {
              "en": "State"
            },
            "values": [
              {
                "id": "any",
                "title": {
                  "en": "Any"
                }
              },
              {
                "id": "boost",
                "title": {
                  "en": "Boost"
                }
              },
              {
                "id": "idle",
                "title": {
                  "en": "Idle"
                }
              },
              {
                "id": "rampdown",
                "title": {
                  "en": "Rampdown"
                }
              },
              {
                "id": "stop",
                "title": {
                  "en": "Stop"
                }
              },
              {
                "id": "unknown",
                "title": {
                  "en": "Unknown"
                }
              }
            ]
          }
        ],
        "tokens": [
          {
            "name": "state",
            "type": "string",
            "title": {
              "en": "State"
            }
          },
          {
            "name": "previous_state",
            "type": "string",
            "title": {
              "en": "Previous state"
            }
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "planned_control_changed"
      },
      {
        "title": {
          "en": "Previous hour heatpump consumption changed",
          "sv": "Föregående timmes värmepumpsförbrukning ändrades"
        },
        "tokens": [
          {
            "name": "consumption_kwh",
            "type": "number",
            "title": {
              "en": "Consumption kWh",
              "sv": "Förbrukning kWh"
            }
          },
          {
            "name": "previous_consumption_kwh",
            "type": "number",
            "title": {
              "en": "Previous consumption kWh",
              "sv": "Föregående förbrukning kWh"
            }
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "previous_hour_heatpump_consumption_changed"
      },
      {
        "title": {
          "en": "Temperature changed"
        },
        "tokens": [
          {
            "name": "temperature_c",
            "type": "number",
            "title": {
              "en": "Temperature"
            }
          },
          {
            "name": "previous_temperature_c",
            "type": "number",
            "title": {
              "en": "Previous temperature"
            }
          }
        ],
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "temperature_changed"
      }
    ],
    "conditions": [
      {
        "title": {
          "en": "Daily heatpump consumption is above"
        },
        "titleFormatted": {
          "en": "Daily heatpump consumption is above [[threshold_kwh]] kWh"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "threshold_kwh",
            "type": "number",
            "title": {
              "en": "Threshold kWh"
            },
            "min": 0,
            "step": 0.1
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "daily_heatpump_consumption_above"
      },
      {
        "title": {
          "en": "Daily heatpump consumption is below",
          "sv": "Dagens värmepumpsförbrukning är under"
        },
        "titleFormatted": {
          "en": "Daily heatpump consumption is below [[threshold_kwh]] kWh",
          "sv": "Dagens värmepumpsförbrukning är under [[threshold_kwh]] kWh"
