        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "threshold_kwh",
            "type": "number",
            "title": {
              "en": "Threshold kWh",
              "sv": "Gränsvärde kWh"
            },
            "min": 0,
            "step": 0.1
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "daily_heatpump_consumption_below"
      },
      {
        "title": {
          "en": "Previous hour heatpump consumption is above",
          "sv": "Föregående timmes värmepumpsförbrukning är över"
        },
        "titleFormatted": {
          "en": "Previous hour heatpump consumption is above [[threshold_kwh]] kWh",
          "sv": "Föregående timmes värmepumpsförbrukning är över [[threshold_kwh]] kWh"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "threshold_kwh",
            "type": "number",
            "title": {
              "en": "Threshold kWh",
              "sv": "Gränsvärde kWh"
            },
            "min": 0,
            "step": 0.1
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "previous_hour_heatpump_consumption_above"
      },
      {
        "title": {
          "en": "Previous hour heatpump consumption is below",
          "sv": "Föregående timmes värmepumpsförbrukning är under"
        },
        "titleFormatted": {
          "en": "Previous hour heatpump consumption is below [[threshold_kwh]] kWh",
          "sv": "Föregående timmes värmepumpsförbrukning är under [[threshold_kwh]] kWh"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "threshold_kwh",
            "type": "number",
            "title": {
              "en": "Threshold kWh",
              "sv": "Gränsvärde kWh"
            },
            "min": 0,
            "step": 0.1
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "previous_hour_heatpump_consumption_below"
      },
      {
        "title": {
          "en": "Temperature is above"
        },
        "titleFormatted": {
          "en": "Temperature is above [[threshold_c]] °C"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "threshold_c",
            "type": "number",
            "title": {
              "en": "Threshold °C"
            },
            "step": 0.1
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "temperature_above"
      },
      {
        "title": {
          "en": "Temperature is below"
        },
        "titleFormatted": {
          "en": "Temperature is below [[threshold_c]] °C"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "threshold_c",
            "type": "number",
            "title": {
              "en": "Threshold °C"
            },
            "step": 0.1
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "temperature_below"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Clear manual plan"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "clear_manual_plan"
      },
      {
        "title": {
          "en": "Refresh Effira asset"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "refresh_asset"
      },
      {
        "title": {
          "en": "Set manual plan"
        },
        "titleFormatted": {
          "en": "Set manual plan to [[action]] from [[start]] until [[end]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "action",
            "type": "dropdown",
            "title": {
              "en": "Action"
            },
            "values": [
              {
                "id": "boost",
                "title": {
                  "en": "Boost"
                }
              },
              {
                "id": "normal",
                "title": {
                  "en": "Normal"
                }
              },
              {
                "id": "stop",
                "title": {
                  "en": "Stop"
                }
              }
            ]
          },
          {
            "name": "start",
            "type": "text",
            "title": {
              "en": "Start UTC"
            },
            "placeholder": {
              "en": "2026-05-06T10:15:00.000Z"
            }
          },
          {
            "name": "end",
            "type": "text",
            "title": {
              "en": "End UTC"
            },
            "placeholder": {
              "en": "2026-05-06T11:00:00.000Z"
            }
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "set_manual_plan"
      },
      {
        "title": {
          "en": "Set manual plan from now"
        },
        "titleFormatted": {
          "en": "Set manual plan to [[action]] for [[duration_minutes]] minutes"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=effira_asset"
          },
          {
            "name": "action",
            "type": "dropdown",
            "title": {
              "en": "Action"
            },
            "values": [
              {
                "id": "boost",
                "title": {
                  "en": "Boost"
                }
              },
              {
                "id": "normal",
                "title": {
                  "en": "Normal"
                }
              },
              {
                "id": "stop",
                "title": {
                  "en": "Stop"
                }
              }
            ]
          },
          {
            "name": "duration_minutes",
            "type": "number",
            "title": {
              "en": "Duration minutes"
            },
            "min": 15,
            "step": 15
          }
        ],
        "platforms": [
          "local"
        ],
        "id": "set_manual_plan_from_now"
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Effira OPTi"
      },
      "class": "other",
      "platforms": [
        "local"
      ],
      "connectivity": [
        "cloud"
      ],
      "images": {
        "small": "/drivers/effira_asset/assets/images/small.png",
        "large": "/drivers/effira_asset/assets/images/large.png",
        "xlarge": "/drivers/effira_asset/assets/images/xlarge.png"
      },
      "capabilities": [
        "measure_temperature",
        "alarm_generic",
        "effira_control_state",
        "effira_heatpump_consumption_day",
        "meter_heatpump_consumption_last_hour"
      ],
      "capabilitiesOptions": {
        "alarm_generic": {
          "title": {
            "en": "Offline",
            "sv": "Offline"
          },
          "titleTrue": {
            "en": "Offline",
            "sv": "Offline"
          },
          "titleFalse": {
            "en": "Online",
            "sv": "Online"
          },
          "insightsTitleTrue": {
            "en": "Device went offline",
            "sv": "Enheten gick offline"
          },
          "insightsTitleFalse": {
            "en": "Device came online",
            "sv": "Enheten kom online"
          }
        }
      },
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "navigation": {
            "next": "list_devices"
          },
          "options": {
            "title": {
              "en": "Connect to Effira"
            },
            "usernameLabel": {
              "en": "Key ID"
            },
            "usernamePlaceholder": {
              "en": "API Key ID"
            },
            "passwordLabel": {
              "en": "Secret"
            },
            "passwordPlaceholder": {
              "en": "API Key secret"
            }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          },
          "options": {
            "singular": true
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "id": "assetId",
          "type": "text",
          "label": {
