          "type": "text",
          "label": {
            "en": "Client ID"
          },
          "value": ""
        },
        {
          "id": "keyId",
          "type": "text",
          "label": {
            "en": "Key ID"
          },
          "value": ""
        },
        {
          "id": "secret",
          "type": "password",
          "label": {
            "en": "Secret"
          },
          "value": ""
        },
        {
          "id": "sensorId",
          "type": "text",
          "label": {
            "en": "Sensor ID"
          },
          "value": ""
        }
      ],
      "id": "effira_asset"
    }
  ],
